---
import Base from "../../layouts/Base.astro";
import Chip from "../../components/Chip";
import { findSection } from "../../lib/sections";
import { getPosts, type WPPost } from "../../lib/wordpress";

export async function getStaticPaths() {
  const posts = await getPosts({ perPage: 100 });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: WPPost;
}

const { post } = Astro.props;
const fecha = new Intl.DateTimeFormat("es", {
  weekday: "long",
  day: "numeric",
  month: "long",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
}).format(new Date(post.date));

const tituloPlano = post.title.replace(/<[^>]*>/g, "");
const seccion = post.categories[0] && findSection(post.categories[0].name);
---

<Base title={`${tituloPlano} — Noticias 33`}>
  <main class="mx-auto max-w-205 px-4 py-6 sm:px-6 md:py-10">
    <article class="border border-n33-ad bg-white p-4 sm:p-6 md:p-10">
      {
        post.categories[0] && (
          <Chip
            label={post.categories[0].name}
            href={seccion ? `/categoria/${seccion.slug}/` : undefined}
          />
        )
      }
      <h1
        class="mt-3 text-2xl font-bold leading-tight text-black sm:text-3xl md:text-4xl"
        set:html={post.title}
      />
      <p
        class="mt-4 border-b border-n33-ad pb-4 font-light capitalize text-n33-text/80"
      >
        Por {post.author} · {fecha}
      </p>
      {
        post.featuredImage && (
          <img
            class="mt-6 w-full"
            src={post.featuredImage.source_url}
            alt={post.featuredImage.alt_text}
          />
        )
      }
      <div class="wp-content mt-6" set:html={post.content} />
    </article>
  </main>
</Base>
