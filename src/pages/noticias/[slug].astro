---
import Base from "../../layouts/Base.astro";
import Chip from "../../components/Chip";
import { categoryHref } from "../../lib/sections";
import { getPostBySlug } from "../../lib/strapi";

export const prerender = false;

const post = await getPostBySlug(Astro.params.slug ?? "");

if (!post) {
  Astro.response.status = 404;
}

const fecha = post
  ? new Intl.DateTimeFormat("es", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(post.date))
  : "";

const tituloPlano = post?.title.replace(/<[^>]*>/g, "") ?? "";
---

{
  !post ? (
    <Base title="No encontrado — Noticias 33">
      <main class="mx-auto max-w-205 px-4 py-16 text-center sm:px-6">
        <h1 class="text-2xl font-bold">Noticia no encontrada</h1>
        <p class="mt-4 text-n33-text/70">
          El artículo que buscas no existe o fue retirado.
        </p>
        <a class="mt-6 inline-block font-bold text-n33-blue underline" href="/">
          Volver al inicio
        </a>
      </main>
    </Base>
  ) : (
    <Base title={`${tituloPlano} — Noticias 33`}>
      <main class="mx-auto max-w-205 px-4 py-6 sm:px-6 md:py-10">
        <article class="border border-n33-ad bg-white p-4 sm:p-6 md:p-10">
          {
            post.categories.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.categories.map((cat) => (
                  <Chip
                    label={cat.name}
                    href={categoryHref(cat.name, cat.slug)}
                  />
                ))}
              </div>
            )
          }
          <h1
            class="mt-3 text-2xl font-bold leading-tight text-black sm:text-3xl md:text-4xl"
            set:html={post.title}
          />
          <p
            class="mt-4 border-b border-n33-ad pb-4 font-light capitalize text-n33-text/80"
          >
            Por {post.author} · {fecha}
          </p>
          {
            post.featuredImage && (
              <img
                class="mt-6 w-full"
                src={post.featuredImage.source_url}
                alt={post.featuredImage.alt_text}
              />
            )
          }
          <div class="wp-content mt-6" set:html={post.content} />
        </article>
      </main>
    </Base>
  )
}
