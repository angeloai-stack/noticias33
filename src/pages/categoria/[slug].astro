---
import Base from "../../layouts/Base.astro";
import { NewsRow } from "../../components/cards";
import { SECTIONS, normalize, type Section } from "../../lib/sections";
import { getCategories, getPosts, type WPPost } from "../../lib/wordpress";

export async function getStaticPaths() {
  const wpCategories = await getCategories();
  return Promise.all(
    SECTIONS.map(async (section) => {
      const match = wpCategories.find(
        (c) =>
          normalize(c.slug) === normalize(section.slug) ||
          normalize(c.name) === normalize(section.name),
      );
      const posts = match
        ? await getPosts({ categoryId: match.id, perPage: 24 })
        : [];
      return {
        params: { slug: section.slug },
        props: { section, posts, description: match?.description ?? "" },
      };
    }),
  );
}

interface Props {
  section: Section;
  posts: WPPost[];
  description: string;
}

const { section, posts, description } = Astro.props;
---

<Base title={`${section.name} — Noticias 33`} description={description}>
  <main class="mx-auto max-w-300 px-6 py-10 lg:px-12">
    <h1
      class="inline-block bg-n33-blue px-5 py-1.5 text-2xl font-bold uppercase text-white [clip-path:polygon(0_0,100%_0,calc(100%-16px)_100%,0_100%)]"
    >
      {section.name}
    </h1>
    {
      posts.length === 0 ? (
        <p class="mt-8 text-n33-text/70">
          Todavía no hay noticias en esta sección.
        </p>
      ) : (
        <section class="mt-10 grid gap-x-12 gap-y-8 md:grid-cols-2">
          {posts.map((post) => (
            <NewsRow post={post} />
          ))}
        </section>
      )
    }
  </main>
</Base>
