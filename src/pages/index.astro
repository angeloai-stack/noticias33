---
import Base from "../layouts/Base.astro";
import Newsletter from "../components/Newsletter";
import RightRail from "../components/RightRail";
import { HeroNews, FeatureNews, NewsRow, PanelNews } from "../components/cards";
import { getPosts } from "../lib/wordpress";

const posts = await getPosts({ perPage: 20 });

// Orden de la portada según el mockup (nodo 6:8):
// 2 mini cards → divisor → destacada "Local" → nota principal →
// parrilla de mini cards → publicidad → panel azul → newsletter.
// A la derecha: reels, clima y publicidad; a la izquierda: banner vertical.
const hero = posts[0];
const feature = posts[1];
const topRows = posts.slice(2, 4);
const midRows = posts.slice(4, 16);
const panel = posts.slice(16, 19);
---

<Base>
  {
    posts.length === 0 ? (
      <main class="mx-auto max-w-360 px-6 py-16 lg:px-12">
        <div class="border border-n33-ad bg-white p-12 text-center">
          <h1 class="text-2xl font-bold">Noticias 33 está casi listo</h1>
          <p class="mt-4">
            No se pudieron cargar noticias desde WordPress. Verifica que la
            variable <code class="bg-n33-bg px-1">WP_URL</code> del archivo
            <code class="bg-n33-bg px-1">.env</code> apunte a tu instalación de
            WordPress y que existan entradas publicadas.
          </p>
        </div>
      </main>
    ) : (
      <>
        <main class="mx-auto max-w-360 px-4 py-8 sm:px-6 md:py-10 lg:px-12">
          <div class="grid gap-10 lg:grid-cols-[116px_1fr_286px]">
            {/* Publicidad lateral izquierda */}
            <aside class="hidden lg:block">
              <div class="flex h-70 items-center justify-center rounded-xl bg-n33-ad">
                <span class="text-lg">Publicidad</span>
              </div>
              <div class="mt-8 flex h-150 items-center justify-center rounded-xl bg-n33-ad">
                <span class="text-lg">Publicidad</span>
              </div>
            </aside>

            {/* Columna central */}
            <div>
              {/* Dos mini cards de relevancia media alta */}
              {topRows.length > 0 && (
                <section class="grid gap-x-12 gap-y-6 md:grid-cols-2 md:gap-y-8">
                  {topRows.map((post, i) => (
                    <NewsRow post={post} delay={i * 80} />
                  ))}
                </section>
              )}

              <hr class="my-8 border-n33-text/40 md:my-10" />

              {/* Destacada de sección (Local) */}
              {feature && (
                <section>
                  <FeatureNews post={feature} />
                </section>
              )}

              {/* Nota principal */}
              {hero && (
                <div class="mt-10 md:mt-14">
                  <HeroNews post={hero} />
                </div>
              )}

              {/* Parrilla de mini cards posterior a la nota principal */}
              {midRows.length > 0 && (
                <section class="mt-10 grid gap-x-12 gap-y-6 md:mt-14 md:grid-cols-2 md:gap-y-8">
                  {midRows.map((post, i) => (
                    <NewsRow post={post} delay={(i % 2) * 80} />
                  ))}
                </section>
              )}

              {/* Publicidad horizontal */}
              <div class="mt-10 flex h-24 items-center justify-center rounded-xl bg-n33-ad md:mt-14 md:h-36.25">
                <span class="text-lg">Publicidad</span>
              </div>
            </div>

            {/* Carril derecho: reels, clima y publicidad */}
            <RightRail />
          </div>
        </main>

        {/* Panel azul: relevancia media baja */}
        {panel.length > 0 && (
          <section class="mx-auto max-w-327.5 px-4 pb-10 sm:px-6 md:pb-14">
            <div class="flex flex-col gap-8 rounded-3xl bg-n33-blue px-5 py-8 md:gap-12 md:rounded-[41px] md:px-20 md:py-12">
              {panel.map((post, i) => (
                <PanelNews post={post} delay={i * 100} />
              ))}
            </div>
          </section>
        )}

        <Newsletter />
      </>
    )
  }
</Base>
