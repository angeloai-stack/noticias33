---
import Base from "../layouts/Base.astro";
import Newsletter from "../components/Newsletter";
import RightRail from "../components/RightRail";
import { HeroNews, FeatureNews, NewsRow, PanelNews } from "../components/cards";
import {
  categoryUrl,
  getCategoryBySlug,
  getPosts,
} from "../lib/strapi";

const [posts, gobiernoCat, politicaCat] = await Promise.all([
  getPosts({ perPage: 20 }),
  getCategoryBySlug("gobierno"),
  getCategoryBySlug("politica"),
]);

const [gobiernoPosts, politicaPosts] = await Promise.all([
  gobiernoCat
    ? getPosts({ categoryId: gobiernoCat.id, perPage: 4 })
    : Promise.resolve([]),
  politicaCat
    ? getPosts({ categoryId: politicaCat.id, perPage: 4 })
    : Promise.resolve([]),
]);

const hero = posts[0];
const feature = posts[1];
const topRows = posts.slice(2, 4);
const midRows = posts.slice(4, 16);
const panel = posts.slice(16, 19);
const latestPosts = posts.slice(0, 6);
---

<Base>
  {
    posts.length === 0 ? (
      <main class="mx-auto max-w-360 px-6 py-16 lg:px-12">
        <div class="border border-n33-ad bg-white p-12 text-center">
          <h1 class="text-2xl font-bold">Noticias 33 está casi listo</h1>
          <p class="mt-4">
            No se pudieron cargar noticias desde Strapi. Verifica que
            <code class="bg-n33-bg px-1">STRAPI_URL</code> y
            <code class="bg-n33-bg px-1">STRAPI_TOKEN</code> estén en tu
            <code class="bg-n33-bg px-1">.env</code> y que existan noticias
            publicadas en el panel de Strapi.
          </p>
        </div>
      </main>
    ) : (
      <>
        <main class="mx-auto max-w-360 px-4 py-6 sm:px-6 md:py-10 lg:px-12">
          <div class="grid gap-8 lg:grid-cols-[116px_1fr_286px] lg:gap-10">
            <aside class="hidden lg:block">
              <div class="flex h-70 items-center justify-center rounded-xl bg-n33-ad">
                <span class="text-lg">Publicidad</span>
              </div>
              <div class="mt-8 flex h-150 items-center justify-center rounded-xl bg-n33-ad">
                <span class="text-lg">Publicidad</span>
              </div>
            </aside>

            <div class="flex flex-col gap-8 md:gap-10">
              {hero && (
                <section class="order-1 md:order-4">
                  <HeroNews post={hero} />
                </section>
              )}

              {topRows.length > 0 && (
                <section class="order-2 grid gap-x-12 gap-y-5 md:order-1 md:grid-cols-2 md:gap-y-8">
                  {topRows.map((post, i) => (
                    <NewsRow post={post} delay={i * 80} />
                  ))}
                </section>
              )}

              <hr class="order-3 hidden border-n33-text/40 md:order-2 md:block" />

              {feature && (
                <section class="order-3 md:order-3">
                  <FeatureNews post={feature} />
                </section>
              )}

              {midRows.length > 0 && (
                <section class="order-4 grid gap-x-12 gap-y-5 md:order-5 md:grid-cols-2 md:gap-y-8 lg:mt-14">
                  {midRows.map((post, i) => (
                    <NewsRow post={post} delay={(i % 2) * 80} />
                  ))}
                </section>
              )}

              <div class="order-5 flex h-20 items-center justify-center rounded-xl bg-n33-ad sm:h-24 md:order-6 md:h-36.25 lg:mt-14">
                <span class="text-base sm:text-lg">Publicidad</span>
              </div>
            </div>

            <RightRail client:visible latestPosts={latestPosts} />
          </div>
        </main>

        {panel.length > 0 && (
          <section class="mx-auto max-w-327.5 px-4 pb-8 sm:px-6 md:pb-14">
            <div class="flex flex-col gap-6 rounded-2xl bg-n33-blue px-4 py-6 sm:gap-8 sm:px-5 sm:py-8 md:gap-12 md:rounded-[41px] md:px-20 md:py-12">
              {panel.map((post, i) => (
                <PanelNews post={post} delay={i * 100} />
              ))}
            </div>
          </section>
        )}

        {
          (gobiernoPosts.length > 0 || politicaPosts.length > 0) && (
            <section class="mx-auto max-w-360 px-4 pb-10 sm:px-6 md:pb-14 lg:px-12">
              <div class="grid gap-12 lg:grid-cols-2">
                {gobiernoCat && gobiernoPosts.length > 0 && (
                  <div>
                    <div class="flex items-center justify-between gap-4">
                      <h2 class="text-2xl font-bold text-n33-blue">
                        {gobiernoCat.name}
                      </h2>
                      <a
                        class="text-sm font-bold text-n33-pink underline"
                        href={categoryUrl(gobiernoCat.slug)}
                      >
                        Ver más
                      </a>
                    </div>
                    <div class="mt-6 space-y-6">
                      {gobiernoPosts.map((post, i) => (
                        <NewsRow post={post} delay={i * 60} />
                      ))}
                    </div>
                  </div>
                )}
                {politicaCat && politicaPosts.length > 0 && (
                  <div>
                    <div class="flex items-center justify-between gap-4">
                      <h2 class="text-2xl font-bold text-n33-blue">
                        {politicaCat.name}
                      </h2>
                      <a
                        class="text-sm font-bold text-n33-pink underline"
                        href={categoryUrl(politicaCat.slug)}
                      >
                        Ver más
                      </a>
                    </div>
                    <div class="mt-6 space-y-6">
                      {politicaPosts.map((post, i) => (
                        <NewsRow post={post} delay={i * 60} />
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </section>
          )
        }

        <Newsletter />
      </>
    )
  }
</Base>
