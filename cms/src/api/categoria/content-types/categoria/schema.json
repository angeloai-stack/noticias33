{
  "kind": "collectionType",
  "collectionName": "categorias",
  "info": {
    "singularName": "categoria",
    "pluralName": "categorias",
    "displayName": "Categoría",
    "description": "Sección editorial (Editorial, Política, Deportes…)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "descripcion": {
      "type": "text"
    },
    "noticias": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::noticia.noticia",
      "mappedBy": "categoria"
    }
  }
}
