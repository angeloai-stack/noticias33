{
  "kind": "collectionType",
  "collectionName": "noticias",
  "info": {
    "singularName": "noticia",
    "pluralName": "noticias",
    "displayName": "Noticia",
    "description": "Artículo de noticias para el sitio N33"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "resumen": {
      "type": "text"
    },
    "cuerpo": {
      "type": "richtext",
      "required": true
    },
    "imagenDestacada": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria",
      "inversedBy": "noticias"
    },
    "autorNombre": {
      "type": "string",
      "default": "Redacción N33"
    }
  }
}
