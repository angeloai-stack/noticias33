# WordPress headless — lectura y publicación vía /wp-json/wp/v2
WP_URL=https://noticias33.com
WP_USER=angeloai@voltlabagency.com
WP_APP_PASSWORD=contraseña-de-aplicacion-de-wordpress

# Panel editorial (/publicar clave 1111, /admin clave 2222)
ACCESS_CODE=1111
ADMIN_CODE=2222

# Supabase — proyecto N33 (Settings → API en supabase.com)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=service-role-key-secreta

# Ejecuta supabase/schema.sql en el SQL Editor antes de usar /admin.
# Verifica todo con: npm run check:config
# Sube variables a Vercel con: npm run setup:vercel-env
# (requiere VERCEL_TOKEN en .env.local — créalo en vercel.com/account/tokens)
