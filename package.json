{
  "name": "n33",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:config": "node scripts/check-config.mjs",
    "cms:dev": "npm run develop --prefix cms",
    "cms:build": "npm run build --prefix cms",
    "cms:export": "npm run export --prefix cms -- --no-encrypt -f ../backups/n33-backup",
    "cms:import": "npm run import --prefix cms -- -f ../backups/n33-backup.tar.gz",
    "cms:test-db": "node scripts/test-supabase-db.mjs",
    "postgres:up": "docker compose -f docker-compose.postgres.yml up -d",
    "postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "setup:vercel-env": "node scripts/push-vercel-env.mjs",
    "setup:vercel-env:ps": "powershell -ExecutionPolicy Bypass -File scripts/push-vercel-env.ps1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@astrojs/vercel": "^11.0.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^7.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
